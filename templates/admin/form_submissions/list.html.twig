{% extends '@ibexadesign/ui/layout.html.twig' %}

{% block title %}Form Submissions{% endblock %}

{%- block breadcrumbs -%}
    {% include '@ibexadesign/ui/breadcrumbs.html.twig' with { items: [
        { value: 'Admin' },
        { value: 'Form Submissions' }
    ]} %}
{%- endblock -%}

{%- block header -%}
    {% include '@ibexadesign/ui/page_title.html.twig' with { title: 'Form Submissions' } %}
{%- endblock -%}

{%- block content -%}
    <section>
        <form method="get" action="{{ path('ibexa_form_builder.submissions_list') }}" class="ibexa-search-links-form">
            <div style="display:inline-block; margin-right:10px;">
                {{ form_row(filterForm.contentId) }}
            </div>
            <div style="display:inline-block; margin-right:10px;">
                {{ form_row(filterForm.dateFrom) }}
            </div>
            <div style="display:inline-block; margin-right:10px;">
                {{ form_row(filterForm.dateTo) }}
            </div>
            {{ form_widget(filterForm.filter, { attr: { class: 'btn ibexa-btn ibexa-btn--primary' } }) }}
        </form>
    </section>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <section class="container ibexa-container">
        <div class="ibexa-table-header">
            <div class="ibexa-table-header__headline">Form Submissions</div>
        </div>

        <div class="ibexa-scrollable-wrapper">
            <table class="ibexa-table table">
                <thead>
                    <tr class="ibexa-table__head-row">
                        <th class="ibexa-table__header-cell">
                            <span class="ibexa-table__header-cell-text-wrapper">#</span>
                        </th>
                        <th class="ibexa-table__header-cell">
                            <span class="ibexa-table__header-cell-text-wrapper">Form Content ID</span>
                        </th>
                        <th class="ibexa-table__header-cell">
                            <span class="ibexa-table__header-cell-text-wrapper">Submitted At</span>
                        </th>
                        <th class="ibexa-table__header-cell">
                            <span class="ibexa-table__header-cell-text-wrapper">IP Address</span>
                        </th>
                        <th class="ibexa-table__header-cell">
                            <span class="ibexa-table__header-cell-text-wrapper"></span>
                        </th>
                    </tr>
                </thead>
                <tbody class="ibexa-table__body">
                    {% for submission in submissions %}
                        <tr class="ibexa-table__row">
                            <td class="ibexa-table__cell">{{ submission.id }}</td>
                            <td class="ibexa-table__cell">{{ submission.contentId }}</td>
                            <td class="ibexa-table__cell">{{ submission.submittedAt|date('Y-m-d H:i:s') }}</td>
                            <td class="ibexa-table__cell">{{ submission.ipAddress ?? '—' }}</td>
                            <td class="ibexa-table__cell ibexa-table__cell--actions">
                                <a href="{{ path('ibexa_form_builder.submission_view', {id: submission.id}) }}"
                                   class="btn ibexa-btn ibexa-btn--ghost">View</a>
                                <form method="post"
                                      action="{{ path('ibexa_form_builder.submission_delete', {id: submission.id}) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Delete submission #{{ submission.id }}?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_submission_' ~ submission.id) }}">
                                    <button type="submit" class="btn ibexa-btn ibexa-btn--ghost-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr class="ibexa-table__row">
                            <td class="ibexa-table__empty-table-cell" colspan="5">
                                <img class="ibexa-table__empty-table-image" src="{{ asset('bundles/ibexaadminui/img/ibexa-empty-table.svg') }}" alt="Table is empty">
                                <div class="ibexa-table__empty-table-text">No submissions found.</div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if submissions.haveToPaginate %}
            <nav>
                <ul class="pagination">
                    {% if submissions.hasPreviousPage %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('ibexa_form_builder.submissions_list', {'page': submissions.previousPage}) }}">‹</a>
                        </li>
                    {% endif %}
                    <li class="page-item disabled">
                        <span class="page-link">{{ submissions.currentPage }} / {{ submissions.nbPages }}</span>
                    </li>
                    {% if submissions.hasNextPage %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('ibexa_form_builder.submissions_list', {'page': submissions.nextPage}) }}">›</a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}
    </section>
{%- endblock -%}
