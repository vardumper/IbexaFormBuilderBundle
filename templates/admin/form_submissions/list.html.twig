{% extends '@ibexadesign/ui/layout.html.twig' %}

{% block title %}Form Submissions{% endblock %}

{%- block breadcrumbs -%}
    {% include '@ibexadesign/ui/breadcrumbs.html.twig' with { items: [
        { value: 'Admin' },
        { value: 'Form Submissions' }
    ]} %}
{%- endblock -%}

{%- block header -%}
    {% include '@ibexadesign/ui/page_title.html.twig' with { title: 'Form Submissions' } %}
{%- endblock -%}

{%- block content -%}
    <section class="container ibexa-container">
        <div class="ibexa-table-header">
            <div class="ibexa-table-header__headline">Form Submissions</div>
        </div>

        <form method="get" action="{{ path('ibexa_form_builder.submissions_list') }}" class="ibexa-form mb-4">
            {{ form_row(filterForm.contentId) }}
            {{ form_row(filterForm.dateFrom) }}
            {{ form_row(filterForm.dateTo) }}
            {{ form_widget(filterForm.filter) }}
        </form>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        <table class="ibexa-table table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Form Content ID</th>
                    <th>Submitted At</th>
                    <th>IP Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for submission in submissions %}
                    <tr>
                        <td>{{ submission.id }}</td>
                        <td>{{ submission.contentId }}</td>
                        <td>{{ submission.submittedAt|date('Y-m-d H:i:s') }}</td>
                        <td>{{ submission.ipAddress ?? '—' }}</td>
                        <td>
                            <a href="{{ path('ibexa_form_builder.submission_view', {id: submission.id}) }}"
                               class="btn btn-sm ibexa-btn ibexa-btn--ghost">View</a>
                            <form method="post"
                                  action="{{ path('ibexa_form_builder.submission_delete', {id: submission.id}) }}"
                                  style="display:inline"
                                  onsubmit="return confirm('Delete submission #{{ submission.id }}?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_submission_' ~ submission.id) }}">
                                <button type="submit" class="btn btn-sm ibexa-btn ibexa-btn--ghost-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-center text-muted">No submissions found.</td></tr>
                {% endfor %}
            </tbody>
        </table>

        {% if submissions.haveToPaginate %}
            <nav>
                <ul class="pagination">
                    {% if submissions.hasPreviousPage %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('ibexa_form_builder.submissions_list', {'page': submissions.previousPage}) }}">‹</a>
                        </li>
                    {% endif %}
                    {% for page in submissions.currentPageResults %}
                    {% endfor %}
                    <li class="page-item disabled">
                        <span class="page-link">{{ submissions.currentPage }} / {{ submissions.nbPages }}</span>
                    </li>
                    {% if submissions.hasNextPage %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('ibexa_form_builder.submissions_list', {'page': submissions.nextPage}) }}">›</a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}
    </section>
{% endblock %}
